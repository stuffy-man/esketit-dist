	quest_links: [ ]
	quests: [
		{
			description: [
				"Металлургия Esketit — путь от первой руды до незеритовой снаряги через плавку и КОВКУ."
				""
				"Зачем это на сервере: металл здесь — ремесло и роль. Руда редкая (крупные залежи), а качество вещи зависит от рук кузнеца. Выгодно специализироваться: кто-то шахтёр, кто-то кузнец, а хорошая снаряга — предмет торговли, а не то, что каждый штампует в одиночку."
				""
				"Крафт на верстаке даёт «кустарный хлам» — статы как у камня. Нормальные вещи куются на наковальне; мастерская работа кузнеца заметно лучше кустарной — отсюда и спрос."
				""
				"Порядок дерева: печь и тигель -> слитки -> ковка меди -> бронза -> железо -> сталь -> розовое золото -> броня -> алмаз -> незерит. Синие инфо-квесты (с иконкой) объясняют механику."
			]
			id: "7E5C000000000000"
			tasks: [{
				disable_toast: true
				icon: {
					Count: 1
					id: "esketit_metallurgy:bloomery_base"
					tag: { }
				}
				id: "7E5C000000000001"
				title: "С чего начать"
				type: "custom"
			}]
			x: 0.0d
			y: -1.4d
		}
		{
			dependencies: ["7E5C000000000006"]
			description: [
				"Металл куётся только раскалённым. Следи за температурой (тултип на слитке):"
				""
				"- Слишком холодно (ниже рабочего порога) — по нему не ударить, грей в горне."
				"- Рабочее / оптимум — куётся; удары в оптимальном жаре дают лучшее качество."
				"- Слишком горячо / расплав — это для домницы и тигля, не для наковальни."
				""
				"Горячий металл жжёт: держи КЛЕЩИ в хотбаре — тогда не обожжёшься. Без клещей раскалённая вещь в инвентаре подожжёт тебя."
				""
				"Остывает само со временем. Нужно мгновенно (остудить голову перед заточкой) — брось в воду: зашипит и остынет."
				""
				"Клещами достаёшь слиток из изложницы ещё горячим — он идёт прямо на наковальню, без повторного нагрева."
			]
			id: "7E5C000000000050"
			tasks: [{
				disable_toast: true
				icon: {
					Count: 1
					id: "esketit_metallurgy:wooden_tongs"
					tag: { }
				}
				id: "7E5C000000000051"
				title: "Температура и клещи"
				type: "custom"
			}]
			x: -2.8d
			y: 0.0d
		}
